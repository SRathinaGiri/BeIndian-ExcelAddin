Public Sub BI_Tool_SamplingLauncher(control As IRibbonControl)
    On Error GoTo ErrHandler
    Unload frmBI_FunctionLauncher
    frmBI_FunctionLauncher.Tag = "BI_MUS_SampleSize"
    frmBI_FunctionLauncher.Show
    Exit Sub
ErrHandler:
    MsgBox "Sampling launcher failed: " & Err.Description, vbExclamation, "BeIndian"
End Sub

Public Sub BI_Tool_ForensicTestsLauncher(control As IRibbonControl)
    On Error GoTo ErrHandler
    Unload frmBI_FunctionLauncher
    frmBI_FunctionLauncher.Tag = "BI_RoundNumbersTest"
    frmBI_FunctionLauncher.Show
    Exit Sub
ErrHandler:
    MsgBox "Forensic tests launcher failed: " & Err.Description, vbExclamation, "BeIndian"
End Sub
