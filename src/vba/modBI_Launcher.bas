Attribute VB_Name = "modBI_Launcher"
Option Explicit

Public Sub BI_Tool_FunctionLauncher(control As IRibbonControl)
    On Error GoTo ErrHandler
    Unload frmBI_FunctionLauncher
    frmBI_FunctionLauncher.Tag = vbNullString
    frmBI_FunctionLauncher.Show
    Exit Sub
ErrHandler:
    MsgBox "Function Launcher failed: " & Err.Description, vbExclamation, "BeIndian"
End Sub

